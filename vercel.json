{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/about-us",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/contact-us",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/how-to-choose-the-right-purse-manufacturer-for-your-brand",
      "destination": "/blog/how-to-choose-the-right-purse-manufacturer-for-your-brand",
      "permanent": true
    },
    {
      "source": "/category/:path*",
      "destination": "/blog",
      "permanent": true
    }
  ]
}
